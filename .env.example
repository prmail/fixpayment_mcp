# Copy this file to .env and fill in your real values.
# Never commit .env to version control.

FIXPAYMENT_DB_HOST=localhost
FIXPAYMENT_DB_PORT=54432
FIXPAYMENT_DB_NAME=fixpayment_db
FIXPAYMENT_DB_USER=fixpayment_user
FIXPAYMENT_DB_PASS=

# Optional: override the upload path for account documents
FIXPAYMENT_UPLOAD_PATH=/var/www/fixpayment/uploads/
